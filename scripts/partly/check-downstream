#!/usr/bin/env python3
"""Discover all downstream Rust crates and TS packages affected by changes
to a given backend app, following both Cargo dependencies and codegen bridges."""

import argparse
import json
import logging
import os
import subprocess
import sys
import tomllib
from collections import deque
from pathlib import Path

# --- Logging ---

LOG_PREFIX = "[@partly/check-downstream]"


class _ColorFormatter(logging.Formatter):
    COLORS = {
        logging.DEBUG: "\033[1;30m",
        logging.INFO: "\033[1;36m",
        logging.WARNING: "\033[1;33m",
        logging.ERROR: "\033[1;31m",
    }
    RESET = "\033[0;37m"
    # INFO_COMPLETE uses green — distinguished via a custom level
    COMPLETE = 25

    def format(self, record: logging.LogRecord) -> str:
        color = self.COLORS.get(record.levelno, self.RESET)
        return f"{color}{LOG_PREFIX} {record.getMessage()}{self.RESET}"


# Custom level for green "complete" messages (between INFO=20 and WARNING=30)
COMPLETE = 25
logging.addLevelName(COMPLETE, "COMPLETE")
_ColorFormatter.COLORS[COMPLETE] = "\033[1;32m"

log = logging.getLogger("check-downstream")
_handler = logging.StreamHandler(sys.stderr)
_handler.setFormatter(_ColorFormatter())
log.addHandler(_handler)
log.setLevel(logging.DEBUG if os.environ.get("PIPELINE_SCRIPTS_DEBUG") == "true" else logging.INFO)


def info_complete(msg: str) -> None:
    log.log(COMPLETE, msg)


def exit_error(msg: str) -> None:
    log.error("Error: %s", msg)
    sys.exit(1)


# --- Repo check ---


def check_repo() -> None:
    try:
        result = subprocess.run(
            ["git", "remote", "-v"],
            capture_output=True,
            text=True,
        )
        if "thepartly/partly" not in result.stdout:
            exit_error("This script must be run inside the thepartly/partly monorepo.")
    except FileNotFoundError:
        exit_error("git is not installed.")


# --- Helpers ---

APPS_PREFIX = Path("packages/backend/apps")
IGNORED_TS_CLIENTS = {"@partly/repairer-server-client-reflect"}


def crate_name_from_toml(toml_path: Path) -> str | None:
    """Extract the [package] name from a Cargo.toml."""
    try:
        data = tomllib.loads(toml_path.read_text())
        return data.get("package", {}).get("name")
    except (OSError, tomllib.TOMLDecodeError):
        return None


def collect_crates_in_app_dir(root: Path, app_dir: Path) -> set[str]:
    """Collect all Rust crate names from Cargo.toml files in an app directory."""
    crates: set[str] = set()
    for toml_path in [root / app_dir / "app" / "Cargo.toml", root / app_dir / "Cargo.toml"]:
        if toml_path.is_file():
            name = crate_name_from_toml(toml_path)
            if name:
                crates.add(name)
    libs_dir = root / app_dir / "libs"
    if libs_dir.is_dir():
        for lib_dir in libs_dir.iterdir():
            if lib_dir.is_dir():
                toml_path = lib_dir / "Cargo.toml"
                if toml_path.is_file():
                    name = crate_name_from_toml(toml_path)
                    if name:
                        crates.add(name)
    return crates


def collect_client_crates_in_app_dir(root: Path, app_dir: Path) -> set[str]:
    """Collect Rust client crate names from *client* dirs in an app's libs/."""
    crates: set[str] = set()
    libs_dir = root / app_dir / "libs"
    if not libs_dir.is_dir():
        return crates
    for lib_dir in libs_dir.iterdir():
        if lib_dir.is_dir() and "client" in lib_dir.name:
            toml_path = lib_dir / "Cargo.toml"
            if toml_path.is_file():
                name = crate_name_from_toml(toml_path)
                if name:
                    crates.add(name)
    return crates


def collect_ts_clients_in_app_dir(root: Path, app_dir: Path) -> set[str]:
    """Collect TS client package names from *client* dirs in an app's libs/."""
    clients: set[str] = set()
    libs_dir = root / app_dir / "libs"
    if not libs_dir.is_dir():
        return clients
    for lib_dir in libs_dir.iterdir():
        if lib_dir.is_dir() and "client" in lib_dir.name:
            pkg_path = lib_dir / "package.json"
            if pkg_path.is_file():
                try:
                    pkg_name = json.loads(pkg_path.read_text()).get("name")
                    if pkg_name and pkg_name not in IGNORED_TS_CLIENTS:
                        clients.add(pkg_name)
                except (OSError, json.JSONDecodeError, KeyError):
                    pass
    return clients


def load_workspace_graph(root: Path) -> tuple[dict[str, set[str]], dict[str, str]]:
    """Load cargo metadata once and build a reverse dependency graph.

    Returns:
        reverse_deps: crate name -> set of workspace crate names that directly depend on it
        crate_manifest_dirs: workspace crate name -> absolute directory containing Cargo.toml
    """
    log.info("Loading cargo metadata...")
    result = subprocess.run(
        ["cargo", "metadata", "--format-version", "1"],
        capture_output=True,
        text=True,
        cwd=root,
    )
    if result.returncode != 0:
        exit_error(f"cargo metadata failed: {result.stderr.strip()}")

    meta = json.loads(result.stdout)
    workspace_member_ids = set(meta.get("workspace_members", []))

    # Map package ID -> (name, manifest_dir, is_workspace)
    pkg_lookup: dict[str, tuple[str, str, bool]] = {}
    crate_manifest_dirs: dict[str, str] = {}

    for pkg in meta["packages"]:
        manifest_path = pkg.get("manifest_path", "")
        manifest_dir = str(Path(manifest_path).parent) if manifest_path else ""
        is_ws = pkg["id"] in workspace_member_ids
        pkg_lookup[pkg["id"]] = (pkg["name"], manifest_dir, is_ws)
        if is_ws:
            crate_manifest_dirs[pkg["name"]] = manifest_dir

    # Build reverse dep graph: reverse_deps[dep] = {workspace crates that depend on dep}
    reverse_deps: dict[str, set[str]] = {}

    for node in meta["resolve"]["nodes"]:
        parent_info = pkg_lookup.get(node["id"])
        if not parent_info or not parent_info[2]:  # skip non-workspace parents
            continue
        parent_name = parent_info[0]
        for dep in node["deps"]:
            dep_info = pkg_lookup.get(dep["pkg"])
            if not dep_info:
                continue
            dep_name = dep_info[0]
            if dep_name not in reverse_deps:
                reverse_deps[dep_name] = set()
            reverse_deps[dep_name].add(parent_name)

    return reverse_deps, crate_manifest_dirs


def find_transitive_reverse_deps(
    reverse_deps: dict[str, set[str]],
    start_crates: set[str],
) -> set[str]:
    """BFS to find all crates that transitively depend on any of the start crates.

    Returns the full set of visited crates including the start crates themselves.
    """
    visited: set[str] = set()
    queue = deque(start_crates)

    while queue:
        crate = queue.popleft()
        if crate in visited:
            continue
        visited.add(crate)
        for rdep in reverse_deps.get(crate, ()):
            if rdep not in visited:
                queue.append(rdep)

    return visited


def app_dir_for_manifest(manifest_dir: str, root_str: str) -> Path | None:
    """Extract the packages/backend/apps/X relative path from a manifest directory."""
    prefix = root_str + "/"
    if not manifest_dir.startswith(prefix):
        return None
    rel = manifest_dir[len(prefix):]
    if rel.startswith("packages/backend/apps/"):
        parts = rel.split("/")
        if len(parts) >= 4:
            return Path("/".join(parts[:4]))
    return None


# --- Main ---


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Discover all downstream Rust crates and TS packages affected by "
        "changes to the given app, following both Cargo dependencies and codegen bridges.",
    )
    parser.add_argument("app_name", metavar="app-name", help="Name of the backend app (e.g. tier1-writer, core-server)")
    parser.add_argument("--run", action="store_true", help="Execute the generated check commands instead of printing them")
    args = parser.parse_args()

    check_repo()

    root = Path.cwd()
    root_str = str(root)
    app_base = APPS_PREFIX / args.app_name
    if not (root / app_base).is_dir():
        exit_error(f"App directory not found: {app_base}")

    log.info(f"Discovering downstream dependencies for {args.app_name}...")

    # Load the full workspace dependency graph once (replaces N sequential
    # cargo tree -i calls with a single cargo metadata invocation).
    reverse_deps, crate_manifest_dirs = load_workspace_graph(root)

    # Identify source app crates (to exclude from downstream results)
    source_app_prefix = str(root / app_base) + "/"
    source_app_crate_names = {
        name for name, mdir in crate_manifest_dirs.items()
        if mdir.startswith(source_app_prefix)
    }

    source_crates = collect_crates_in_app_dir(root, app_base)
    all_crates: set[str] = set()
    known_app_dirs: set[Path] = {app_base}
    checked_crates: set[str] = set()
    crates_to_check = set(source_crates)

    for iteration in range(1, 11):
        if not crates_to_check:
            break

        log.info(f"BFS iteration {iteration}: checking {len(crates_to_check)} crate(s)...")

        # In-memory BFS over the reverse dep graph (instant vs seconds per crate)
        all_rdeps = find_transitive_reverse_deps(reverse_deps, crates_to_check)
        checked_crates.update(crates_to_check)

        # Exclude source app crates — they are not downstream
        new_crates = all_rdeps - source_app_crate_names
        all_crates.update(new_crates)

        # Discover new app directories from reverse deps
        new_app_dirs: set[Path] = set()
        for crate_name in new_crates:
            mdir = crate_manifest_dirs.get(crate_name, "")
            adir = app_dir_for_manifest(mdir, root_str)
            if adir and adir not in known_app_dirs:
                new_app_dirs.add(adir)

        if not new_app_dirs:
            log.debug("  No new app dirs discovered, BFS complete")
            break

        log.info(f"  Found new app dirs: {' '.join(str(d) for d in sorted(new_app_dirs))}")
        known_app_dirs.update(new_app_dirs)

        # For next iteration: find client crates in the new app dirs that we haven't checked yet
        crates_to_check = set()
        for app_dir in new_app_dirs:
            for cc in collect_client_crates_in_app_dir(root, app_dir):
                if cc not in checked_crates:
                    crates_to_check.add(cc)
    else:
        log.warning("BFS iteration limit reached, stopping")

    # --- TS client packages ---

    all_ts_clients: set[str] = set()
    for app_dir in known_app_dirs:
        all_ts_clients.update(collect_ts_clients_in_app_dir(root, app_dir))

    # --- Build commands ---

    sorted_crates = sorted(all_crates)
    cargo_packages = " ".join(f"-p {c}" for c in sorted_crates)
    cargo_cmd = f"cargo check --all-targets --all-features {cargo_packages}"

    sorted_ts = sorted(all_ts_clients)
    pnpm_filters = " ".join(f'--filter="{pkg}..."' for pkg in sorted_ts)
    pnpm_cmd = f"pnpm {pnpm_filters} build" if pnpm_filters else ""

    # --- Output ---

    info_complete(f"Found {len(sorted_crates)} Rust crate(s) across {len(known_app_dirs)} app(s)")
    if all_ts_clients:
        info_complete(f"Found {len(all_ts_clients)} TS client package(s)")

    print()

    if args.run:
        log.info("Running cargo check...")
        result = subprocess.run(cargo_cmd, shell=True)
        if result.returncode != 0:
            exit_error("cargo check failed")
        if pnpm_cmd:
            log.info("Running pnpm build...")
            result = subprocess.run(pnpm_cmd, shell=True)
            if result.returncode != 0:
                exit_error("pnpm build failed")
        info_complete("All checks passed")
    else:
        print(cargo_cmd)
        if pnpm_cmd:
            print()
            print(pnpm_cmd)


if __name__ == "__main__":
    main()
